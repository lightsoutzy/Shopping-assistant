# ── LLM ───────────────────────────────────────────────────────────────────────
# Anthropic API key — keep server-side only, never commit
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Dataset paths (local preprocessing only) ──────────────────────────────────
# Path to the raw Kaggle dataset root (contains images/ and styles.csv).
# Only needed locally to run: python -m app.data.preprocess_dataset
# Not needed on Railway — the processed artifacts are committed to the repo.
DATASET_ROOT=data/fashion-dataset/fashion-dataset

# Processed artifacts — committed to repo; override only if moved elsewhere.
CATALOG_PATH=data/processed/catalog.parquet
EMBEDDINGS_PATH=data/processed/image_embeddings.npy
EMBEDDING_IDS_PATH=data/processed/embedding_ids.npy

# ── Demo rate limiting ────────────────────────────────────────────────────────
MAX_REQUESTS_PER_SESSION=20
MAX_TOTAL_REQUESTS=500

# ── Backend server (local dev) ────────────────────────────────────────────────
# Used when running frontend + backend separately on the same machine.
API_HOST=localhost
API_PORT=8000

# ── Deployed frontend → backend URL ───────────────────────────────────────────
# Set this in Streamlit Community Cloud secrets when deploying.
# When set, the Streamlit frontend calls this URL instead of localhost.
# Leave blank for local dev (API_HOST + API_PORT are used automatically).
# Example: https://your-app.railway.app
API_URL=
