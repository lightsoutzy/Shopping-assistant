# .streamlit/secrets.toml.example
#
# Copy this file to .streamlit/secrets.toml for local Streamlit testing,
# OR paste the key=value pairs directly into Streamlit Community Cloud →
# App settings → Secrets (the cloud UI accepts TOML format).
#
# .streamlit/secrets.toml is gitignored — never commit the real file.

# URL of the deployed FastAPI backend (Railway, Render, Fly.io, etc.)
# The Streamlit app reads this via os.getenv("API_URL").
API_URL = "https://your-backend.railway.app"
