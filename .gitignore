# Environment — never commit any .env variant
.env
*.env
.env.txt
.env.local

# Raw dataset — never commit (too large)
data/fashion-dataset/

# Processed data — raw dataset excluded; small artifacts committed for Railway deploy
data/processed/*
!data/processed/catalog.parquet
!data/processed/image_embeddings.npy
!data/processed/embedding_ids.npy

# Streamlit Cloud local secrets — never commit real secrets
.streamlit/secrets.toml

# Thumbnails — committed (~40MB, serves product images in deployed demo)
# Generated by: python -m app.data.build_thumbnails

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.iml
